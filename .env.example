# JWT — api-gateway (validación), release-service (emisión de tokens)
JWT_SECRET=example
JWT_EXPIRY=24h

# SQLite — release-service (TypeORM + better-sqlite3)
DB_PATH=./data/releases.db

# Usuario admin inicial (seed)
ADMIN_EMAIL=correo@example
ADMIN_PASSWORD=example123

# GitHub — integration-service (@octokit/rest)
GITHUB_TOKEN=

# SMTP — notification-service (Nodemailer + Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# URLs entre microservicios (usar process.env.*_SERVICE_URL en código)
RELEASE_SERVICE_URL=http://localhost:3001
RULES_SERVICE_URL=http://localhost:3002
INTEGRATION_SERVICE_URL=http://localhost:3003
NOTIFICATION_SERVICE_URL=http://localhost:3004
