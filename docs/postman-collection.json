{
  "info": {
    "name": "Release Approval — PoC",
    "description": "Colección alineada con docs/SMOKE-TESTS.md. Swagger gateway: http://localhost:3000/docs\n\nTras Login, copia access_token en la variable de colección \"token\".",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "gatewayUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "releaseServiceUrl",
      "value": "http://localhost:3001"
    },
    {
      "key": "rulesServiceUrl",
      "value": "http://localhost:3002"
    },
    {
      "key": "integrationServiceUrl",
      "value": "http://localhost:3003"
    },
    {
      "key": "notificationServiceUrl",
      "value": "http://localhost:3004"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "releaseId",
      "value": "00000000-0000-0000-0000-000000000000"
    },
    {
      "key": "ruleId",
      "value": "1"
    },
    {
      "key": "owner",
      "value": "JulianMbp"
    },
    {
      "key": "repo",
      "value": "rpeo-prueba-ci"
    },
    {
      "key": "prNumber",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "API Gateway (3000)",
      "item": [
        {
          "name": "release-service (proxy)",
          "item": [
            {
              "name": "Login (JWT)",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "url": "{{gatewayUrl}}/api/auth/login",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"admin@empresa.com\",\n  \"password\": \"Admin123!\"\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                }
              }
            },
            {
              "name": "Login incorrecto (401)",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "url": "{{gatewayUrl}}/api/auth/login",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"admin@empresa.com\",\n  \"password\": \"incorrecta\"\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                }
              }
            },
            {
              "name": "Crear release",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{token}}"
                  }
                ],
                "url": "{{gatewayUrl}}/api/releases",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"fecha\": \"2026-04-19\",\n  \"equipo\": \"Equipo PoC\",\n  \"tipo\": \"rs\",\n  \"descripcion\": \"Ejemplo vía gateway\",\n  \"prIdentifier\": \"JIRA-1\",\n  \"cobertura\": 85,\n  \"stack\": [\n    {\n      \"framework\": \"angular\",\n      \"version\": \"17.3.1\"\n    }\n  ],\n  \"approverEmail\": \"aprobador@empresa.com\"\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                }
              }
            },
            {
              "name": "Listar releases",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{token}}"
                  }
                ],
                "url": "{{gatewayUrl}}/api/releases"
              }
            },
            {
              "name": "Obtener release por id",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{token}}"
                  }
                ],
                "url": "{{gatewayUrl}}/api/releases/{{releaseId}}"
              }
            },
            {
              "name": "Aprobar release (solo admin)",
              "request": {
                "method": "PATCH",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{token}}"
                  }
                ],
                "url": "{{gatewayUrl}}/api/releases/{{releaseId}}/approve",
                "body": {
                  "mode": "raw",
                  "raw": "{}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                }
              }
            },
            {
              "name": "Listar reglas",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{token}}"
                  }
                ],
                "url": "{{gatewayUrl}}/api/rules"
              }
            },
            {
              "name": "Actualizar regla (activa / config)",
              "request": {
                "method": "PATCH",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{token}}"
                  }
                ],
                "url": "{{gatewayUrl}}/api/rules/{{ruleId}}",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"activa\": true,\n  \"config\": {\n    \"minCoverage\": 80\n  }\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                }
              }
            }
          ]
        },
        {
          "name": "integration-service (proxy)",
          "item": [
            {
              "name": "Cobertura desde checks/comentarios del PR",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{token}}"
                  }
                ],
                "url": "{{gatewayUrl}}/api/coverage/{{owner}}/{{repo}}/{{prNumber}}"
              }
            }
          ]
        }
      ]
    },
